# ── Database ─────────────────────────────────────────────
# Option A: full connection string (recommended for Railway/Render)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sidequestworld

# Option B: individual fields (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASS=password
# DB_NAME=sidequestworld

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
